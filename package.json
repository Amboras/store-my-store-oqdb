{
  "name": "ecom-starter-template",
  "version": "1.0.0",
  "private": true,
  "description": "AI-powered ecommerce store builder with Medusa",
  "workspaces": [
    "backend",
    "storefront"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:storefront\"",
    "dev:backend": "cd backend && npm run dev",
    "dev:storefront": "cd storefront && npm run dev",
    "build": "npm run build --workspaces",
    "install:all": "npm install && npm install --workspaces",
    "type-check": "npm run type-check --workspaces --if-present",
    "clean": "rm -rf node_modules backend/node_modules storefront/node_modules"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
